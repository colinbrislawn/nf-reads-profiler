// Local skipCompleted regression test (no MEDI).
//
// Exercises the skipCompleted re-injection fix (PR #7): on a -resume / second
// invocation, samples whose per-sample outputs already exist are branched out at
// ingest and must be re-injected into the study-level combines so the combined
// tables stay complete instead of truncating to only the freshly-run samples.
//
// MEDI is OFF (needs the 512 GB-RAM box + Kraken2 hash DB, not present here).
// This covers the HUMAnN + MetaPhlAn re-injection paths only.
//
// Run:
//   nextflow run main.nf -profile test_skip            # phase A (fresh)
//   nextflow run main.nf -profile test_skip -resume    # phase B (skip-resume)
//
// Real HUMAnN4 v4 + MetaPhlAn DBs served from /home/ubuntu/disk_dbs (Docker-mountable).

includeConfig 'test.config'

// test.config caps every process at 8 GB — too small for bowtie2 against the real
// vOct22/vJan25 MetaPhlAn indexes (~18 GB resident), which OOM-kills (exit 137).
// Give the profiling steps real memory and serialize so we stay under this box's 61 GB.
executor {
    queueSize = 2
}
process {
    withName: 'profile_taxa' {
        cpus   = 4
        memory = 22.GB
    }
    withName: 'profile_function' {
        cpus   = 4
        memory = 45.GB
    }
}

// Bind the real DB tree into every container (test.config / nextflow.config only
// mount /mnt/scratch/ssddbs, which doesn't exist on this VM).
docker {
    enabled    = true
    runOptions = "--user \$(id -u):\$(id -g) -v /home/ubuntu/disk_dbs:/home/ubuntu/disk_dbs"
}

params {
    input      = "$projectDir/assets/samplesheet-test-local.csv"
    outdir     = "$projectDir/results_unskip"
    project    = "test_skip"

    enable_medi = false
    skipHumann  = false

    // Real MetaPhlAn + HUMAnN4 DBs (override test.config's toy DBs).
    direct_metaphlan_id = "mpa_vJan25_CHOCOPhlAnSGB_202503"
    direct_metaphlan_db = "/home/ubuntu/disk_dbs/metaphlan_databases/vJan25/"
    humann_metaphlan_id = "mpa_vOct22_CHOCOPhlAnSGB_202403"
    humann_metaphlan_db = "/home/ubuntu/disk_dbs/metaphlan_databases/vOct22/"
    humann_chocophlan   = "/home/ubuntu/disk_dbs/chocophlan_v4_alpha/"
    humann_uniref       = "/home/ubuntu/disk_dbs/uniref90_annotated_v4_alpha_ec_filtered/"
    humann_utilitymap   = "/home/ubuntu/disk_dbs/full_mapping_v4_alpha/"

    // Keep the run fast: bypass the diamond translated search (MEDI not used).
    humann_extraparams = "--bypass-translated-search"

    nreads   = 10000
    minreads = 100
}

// Keep work dir + outputs so a -resume run can re-inject published per-sample files.
cleanup = false
